<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestApp"
        xmlns:controls="clr-namespace:TestApp.Controls"
        mc:Ignorable="d"
        Title="TestApp" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 메인 화면 (UserControl 조합 골격) -->
        <controls:ucMain x:Name="uMain" Grid.Column="0" />

        <!-- 추가 화면 (순수 code-behind 카운터) -->
        <controls:ucContent x:Name="uContent" Grid.Column="1" />

        <!-- MVVM 화면 (ViewModel 바인딩 카운터) -->
        <controls:ucMvvmCounter x:Name="uMvvmCounter" Grid.Column="2" />
    </Grid>
</Window>
