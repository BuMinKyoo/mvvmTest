<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WpfApp1.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Basic MVVM Sample" Height="360" Width="520">
    <Window.Resources>
        <converters:BoolTextConverter x:Key="BoolTextConverter" />
        <converters:CountToBackgroundConverter x:Key="CountToBackgroundConverter" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="기본 MVVM 예제"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid DataContext="{Binding Greeting}">
                <StackPanel>
                    <TextBlock Text="GreetingViewModel"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="이름"
                                   Width="60"
                                   VerticalAlignment="Center" />
                        <TextBox Text="{Binding Person.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Width="140" />
                    </StackPanel>

                    <Button Content="인사말 만들기"
                            Width="120"
                            HorizontalAlignment="Left"
                            Command="{Binding MakeGreetingCommand}" />

                    <TextBlock Text="{Binding GreetingMessage}"
                               FontSize="16"
                               Margin="0,16,0,0" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2"
                  DataContext="{Binding Counter}">
                <StackPanel>
                    <TextBlock Text="CounterViewModel"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <TextBlock Text="{Binding Count}"
                               Background="{Binding Count, Converter={StaticResource CountToBackgroundConverter}}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Padding="8,4"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="카운트 증가"
                                Width="120"
                                Command="{Binding IncreaseCommand}" />
                        <Button Content="카운트 감소"
                                Width="120"
                                Margin="8,0,0,0"
                                Command="{Binding DecreaseCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
